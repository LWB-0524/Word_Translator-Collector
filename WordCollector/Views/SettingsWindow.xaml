<Window x:Class="WordCollector.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置 · WordCollector"
        Icon="/Assets/wordcollector.ico"
        Width="680" Height="780" MinWidth="600" MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        FontFamily="{StaticResource UiFont}"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style x:Key="SettingsHeading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>
        <Style x:Key="KeyCap" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SubtleBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="26,24,26,22">
                <TextBlock Text="设置" FontFamily="{StaticResource DisplayFont}"
                           FontSize="27" FontWeight="SemiBold"/>
                <TextBlock Text="外观、AI 服务和使用习惯都在这里。"
                           FontSize="14" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,5,0,22"/>

                <Border Style="{StaticResource SectionPanel}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="外观" Style="{StaticResource SettingsHeading}"/>
                        <TextBlock Text="主题会立即应用，也可以从主窗口标题栏快速切换。"
                                   FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,5,0,18"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="色调" Style="{StaticResource SettingsLabel}"/>
                                <ComboBox ItemsSource="{Binding ThemeModes}" DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code" SelectedValue="{Binding ThemeMode}"
                                          Style="{StaticResource ModernComboBox}" Height="42"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="主题色" Style="{StaticResource SettingsLabel}"/>
                                <ComboBox ItemsSource="{Binding ThemeAccents}" DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code" SelectedValue="{Binding AccentColor}"
                                          Style="{StaticResource ModernComboBox}" Height="42"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionPanel}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="AI 服务" Style="{StaticResource SettingsHeading}"/>
                        <TextBlock Text="用于查询释义；密钥只加密保存在本机。"
                                   FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,5,0,18"/>

                        <TextBlock Text="服务商" Style="{StaticResource SettingsLabel}"/>
                        <ComboBox ItemsSource="{Binding AiProviders}" SelectedItem="{Binding AiProvider}"
                                  Style="{StaticResource ModernComboBox}" Height="42" Margin="0,0,0,15"/>

                        <TextBlock Text="API Key" Style="{StaticResource SettingsLabel}"/>
                        <PasswordBox x:Name="ApiKeyBox" PasswordChar="●" Height="42" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="0.85*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Base URL" Style="{StaticResource SettingsLabel}"/>
                                <TextBox Text="{Binding AiBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="42"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="模型" Style="{StaticResource SettingsLabel}"/>
                                <TextBox Text="{Binding AiModel, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Height="42"/>
                            </StackPanel>
                        </Grid>

                        <WrapPanel Margin="0,18,0,0">
                            <Button Content="测试连接" Click="TestConnection_Click"
                                    Style="{StaticResource OutlineButton}" Padding="15,9" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionPanel}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="朗读" Style="{StaticResource SettingsHeading}"/>
                        <TextBlock Text="选择系统语音，并控制查询后的自动朗读。"
                                   FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,5,0,18"/>
                        <CheckBox Content="启用英文朗读" IsChecked="{Binding TtsEnabled}" Margin="0,0,0,16"/>

                        <TextBlock Text="朗读语音" Style="{StaticResource SettingsLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailableVoices}" SelectedItem="{Binding TtsVoiceName}"
                                  Style="{StaticResource ModernComboBox}" Height="42" Margin="0,0,0,16"/>

                        <TextBlock Text="朗读速度" Style="{StaticResource SettingsLabel}"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="慢" Style="{StaticResource OutlineButton}" Click="SlowRate_Click"
                                    Width="62" Padding="10,8" Margin="0,0,8,0"/>
                            <Button Content="正常" Style="{StaticResource OutlineButton}" Click="NormalRate_Click"
                                    Width="62" Padding="10,8" Margin="0,0,8,0"/>
                            <Button Content="快" Style="{StaticResource OutlineButton}" Click="FastRate_Click"
                                    Width="62" Padding="10,8"/>
                            <TextBlock Text="{Binding TtsRate, StringFormat='当前速率：{0}'}" VerticalAlignment="Center"
                                       Margin="16,0,0,0" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"/>
                        </StackPanel>
                        <CheckBox Content="查询成功后自动朗读" IsChecked="{Binding AutoSpeakAfterQuery}" Margin="0,17,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionPanel}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="窗口与快捷操作" Style="{StaticResource SettingsHeading}"/>
                        <TextBlock Text="调整置顶、自动隐藏与 Ctrl+Enter 的行为。"
                                   FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,5,0,18"/>
                        <CheckBox Content="启动后默认置顶" IsChecked="{Binding AlwaysOnTop}" Margin="0,0,0,13"/>
                        <CheckBox Content="查询后自动隐藏窗口" IsChecked="{Binding AutoHideAfterQuery}" Margin="0,0,0,17"/>
                        <TextBlock Text="Ctrl+Enter 后" Style="{StaticResource SettingsLabel}"/>
                        <ComboBox ItemsSource="{Binding CtrlEnterBehaviors}" SelectedItem="{Binding CtrlEnterBehavior}"
                                  Style="{StaticResource ModernComboBox}" Height="42"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionPanel}">
                    <StackPanel>
                        <TextBlock Text="快捷键" Style="{StaticResource SettingsHeading}" Margin="0,0,0,6"/>
                        <TextBlock Text="点击下方方框再按下想要的组合键即可修改全局快捷键（需包含 Ctrl / Alt / Shift / Win）。保存后立即生效。"
                                   FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBox Tag="ShowWindow" HorizontalAlignment="Left" Width="196" Height="38"
                                     Text="{Binding ShowWindowHotkeyDisplay, Mode=OneWay}"
                                     IsReadOnly="True" IsReadOnlyCaretVisible="False" Cursor="Hand"
                                     Style="{StaticResource ModernTextBox}" FontFamily="Consolas" FontSize="12"
                                     TextAlignment="Center" VerticalContentAlignment="Center"
                                     ToolTip="点击后按下新的快捷键组合；按 Esc 取消，按 Backspace 恢复默认"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                            <TextBlock Grid.Column="1" Text="显示快速捕获窗口" VerticalAlignment="Center" Margin="14,0,0,0"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBox Tag="QuickQuery" HorizontalAlignment="Left" Width="196" Height="38"
                                     Text="{Binding QuickQueryHotkeyDisplay, Mode=OneWay}"
                                     IsReadOnly="True" IsReadOnlyCaretVisible="False" Cursor="Hand"
                                     Style="{StaticResource ModernTextBox}" FontFamily="Consolas" FontSize="12"
                                     TextAlignment="Center" VerticalContentAlignment="Center"
                                     ToolTip="点击后按下新的快捷键组合；按 Esc 取消，按 Backspace 恢复默认"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                            <TextBlock Grid.Column="1" Text="读取剪贴板并直接查询" VerticalAlignment="Center" Margin="14,0,0,0"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>

                        <TextBlock x:Name="HotkeyHint" Text="" FontSize="12" Visibility="Collapsed"
                                   Foreground="{DynamicResource DangerBrush}" Margin="2,2,0,14"
                                   TextWrapping="Wrap"/>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,14"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Style="{StaticResource KeyCap}" HorizontalAlignment="Left"><TextBlock Text="Enter" FontFamily="Consolas" FontSize="12"/></Border>
                            <TextBlock Grid.Column="1" Text="查询释义并自动保存" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Style="{StaticResource KeyCap}" HorizontalAlignment="Left"><TextBlock Text="Ctrl + L / Esc" FontFamily="Consolas" FontSize="12"/></Border>
                            <TextBlock Grid.Column="1" Text="清空当前内容 / 隐藏到托盘" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="26,15">
            <Grid>
                <Button Content="恢复默认" Click="ResetDefaults_Click" HorizontalAlignment="Left"
                        Style="{StaticResource OutlineButton}" Padding="17,10"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="取消" IsCancel="True" Style="{StaticResource OutlineButton}"
                            Width="88" Margin="0,0,10,0"/>
                    <Button Content="保存设置" Click="Save_Click" IsDefault="True"
                            Style="{StaticResource PrimaryButton}" Width="108"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
