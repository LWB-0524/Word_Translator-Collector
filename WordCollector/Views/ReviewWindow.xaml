<Window x:Class="WordCollector.Views.ReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WordCollector.Converters"
        Title="每日复盘 · WordCollector"
        Icon="/Assets/wordcollector.ico"
        Width="1040" Height="720" MinWidth="860" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        FontFamily="{StaticResource UiFont}"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:FamiliarityToColorConverter x:Key="FamColor"/>
        <converters:FamiliarityToTextConverter x:Key="FamText"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>
        <Style x:Key="ListCard" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card" Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                Padding="18,15">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource BorderFocusBrush}"/>
                                <Setter TargetName="Card" Property="BorderThickness" Value="3,0,0,1"/>
                                <Setter TargetName="Card" Property="Padding" Value="15,15,18,15"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="2,0,2,16">
            <StackPanel>
                <TextBlock Text="每日复盘" FontFamily="{StaticResource DisplayFont}"
                           FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Text="回看今天沉淀的表达，保持一点点长期积累。"
                           FontSize="14" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,5,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource PrimaryButton}" Padding="16,9" Margin="0,0,10,0"
                        Command="{Binding StartReviewCommand}"
                        Content="{Binding Statistics.DueToday, StringFormat='开始复习 · {0}'}"
                        Visibility="{Binding IsReviewMode, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                <Button Style="{StaticResource OutlineButton}" Padding="16,9" Margin="0,0,10,0"
                        Content="退出复习" Command="{Binding ExitReviewCommand}"
                        Visibility="{Binding IsReviewMode, Converter={StaticResource BoolToVis}}"/>
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="7" Padding="12,7" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource SectionPanel}" Padding="6" Margin="0,0,0,16">
            <UniformGrid Rows="1" Columns="5">
                <StackPanel Margin="10,8">
                    <TextBlock Text="{Binding Statistics.TotalItems}" FontFamily="{StaticResource DisplayFont}"
                               FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="总词条" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Margin="10,8">
                    <TextBlock Text="{Binding Statistics.DueToday}" FontFamily="{StaticResource DisplayFont}"
                               FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock Text="今日待复习" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Margin="10,8">
                    <TextBlock Text="{Binding Statistics.CurrentStreak}" FontFamily="{StaticResource DisplayFont}"
                               FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource FamLearningBrush}"/>
                    <TextBlock Text="连续打卡(天)" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Margin="10,8">
                    <TextBlock Text="{Binding Statistics.MasteredCount}" FontFamily="{StaticResource DisplayFont}"
                               FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource FamMasteredBrush}"/>
                    <TextBlock Text="已掌握" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Margin="10,8">
                    <TextBlock Text="{Binding Statistics.ActiveDays}" FontFamily="{StaticResource DisplayFont}"
                               FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="学习天数" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource SectionPanel}" Padding="14" Margin="0,0,0,16"
                Visibility="{Binding IsReviewMode, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="日期" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="2,0,7,0"/>
                <ComboBox ItemsSource="{Binding Dates}" Text="{Binding SelectedDate, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True" Width="132" Height="38" Margin="0,0,8,0"
                          Style="{StaticResource ModernComboBox}" SelectionChanged="Date_Changed"/>
                <Button Content="今天" Style="{StaticResource ToolbarButton}"
                        Command="{Binding LoadTodayCommand}" Height="38" Margin="0,0,10,0"/>
                <CheckBox Content="全部日期" IsChecked="{Binding SearchAllDates}"
                          VerticalAlignment="Center" FontSize="13"
                          Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,14,0"
                          ToolTip="跨所有日期搜索，忽略上方选中的日期"/>

                <Border Width="1" Height="26" Background="{DynamicResource BorderBrush}" Margin="0,0,14,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Width="168" Height="38" Margin="0,0,8,0" VerticalContentAlignment="Center"
                         Style="{StaticResource ModernTextBox}" ToolTip="搜索英文或中文释义">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Content="搜索" Style="{StaticResource ToolbarButton}"
                        Command="{Binding SearchCommand}" Height="38" Margin="0,0,14,0"/>

                <ComboBox ItemsSource="{Binding ItemTypeOptions}" SelectedItem="{Binding SelectedType}"
                          Width="92" Height="38" Margin="0,0,8,0"
                          Style="{StaticResource ModernComboBox}" SelectionChanged="ItemType_Changed"/>
                <ComboBox ItemsSource="{Binding FamiliarityOptions}" SelectedItem="{Binding SelectedFamiliarity}"
                          Width="100" Height="38" Margin="0,0,8,0"
                          Style="{StaticResource ModernComboBox}" ToolTip="按熟悉程度筛选"/>
                <ComboBox ItemsSource="{Binding SortModeOptions}" SelectedItem="{Binding SortMode}"
                          Width="122" Height="38" Margin="0,0,14,0"
                          Style="{StaticResource ModernComboBox}" SelectionChanged="SortMode_Changed"/>

                <Button Content="导出 MD" Style="{StaticResource ToolbarButton}"
                        Command="{Binding ExportMarkdownCommand}" Height="38" Margin="0,0,8,0"/>
                <Button Content="导出 CSV" Style="{StaticResource ToolbarButton}"
                        Command="{Binding ExportCsvCommand}" Height="38"/>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.08*" MinWidth="360"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="0.92*" MinWidth="340"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionPanel}" Padding="0" ClipToBounds="True">
                <Grid>
                    <ListBox x:Name="EntryListBox" ItemsSource="{Binding Entries}"
                             SelectedItem="{Binding SelectedEntry}" ItemContainerStyle="{StaticResource ListCard}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="EntryListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Text}" FontSize="16" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Phonetic}" FontSize="13"
                                                       Foreground="{DynamicResource TextTertiaryBrush}" Margin="9,2,0,0"
                                                       Visibility="{Binding Phonetic, Converter={StaticResource StringToVis}}"/>
                                        </StackPanel>
                                        <Border HorizontalAlignment="Right" Style="{StaticResource FamiliarityTag}"
                                                Background="{Binding Familiarity, Converter={StaticResource FamColor}}">
                                            <TextBlock Text="{Binding Familiarity, Converter={StaticResource FamText}}"
                                                       FontSize="11" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding MeaningZh}" FontSize="14"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,0,145,0"/>
                                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                            <TextBlock FontSize="12" Foreground="{DynamicResource PrimaryBrush}">
                                                <Run Text="查询 "/><Run Text="{Binding LookupCount}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" Margin="10,0,0,0">
                                                <Run Text="朗读 "/><Run Text="{Binding SpokenCount}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Entries.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="今天还没有可复盘的内容" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="查询过的表达会自动出现在这里" FontSize="13"
                                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,7,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionPanel}" Padding="22"
                    Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <TextBlock Text="词条详情" FontSize="19" FontWeight="SemiBold"/>
                            <Button Content="朗读" HorizontalAlignment="Right" Style="{StaticResource SpeakButton}"
                                    Command="{Binding SpeakCommand}" CommandParameter="{Binding DetailItem}" Padding="12,7"/>
                        </Grid>

                        <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="9" Padding="14" Margin="0,0,0,18"
                                Visibility="{Binding IsReviewMode, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="还记得这个表达吗？" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="根据回忆情况评分，下次复习时间会自动安排。" FontSize="12"
                                           Foreground="{DynamicResource TextTertiaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                <UniformGrid Rows="1" Columns="3">
                                    <Button Content="忘记" Style="{StaticResource DangerButton}" Margin="0,0,6,0"
                                            Command="{Binding GradeReviewCommand}" CommandParameter="forgot"/>
                                    <Button Content="模糊" Style="{StaticResource OutlineButton}" Margin="0,0,6,0"
                                            Command="{Binding GradeReviewCommand}" CommandParameter="hard"/>
                                    <Button Content="记得" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding GradeReviewCommand}" CommandParameter="good"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="英文原文" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding DetailItem.Text, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                        <TextBlock Text="音标" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding DetailItem.Phonetic}" FontFamily="{StaticResource DisplayFont}"
                                   FontSize="16" Foreground="{DynamicResource PrimaryBrush}" Margin="2,0,0,15"
                                   Visibility="{Binding DetailItem.Phonetic, Converter={StaticResource StringToVis}}"/>

                        <TextBlock Text="中文释义" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding DetailItem.MeaningZh, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" MinHeight="64" TextWrapping="Wrap"
                                 AcceptsReturn="True" Margin="0,0,0,15"/>

                        <TextBlock Text="用法说明" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding DetailItem.BriefExplanation}" FontSize="14" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="1,0,1,15"/>

                        <TextBlock Text="例句" Style="{StaticResource FieldLabel}"/>
                        <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBox Text="{Binding DetailItem.ExampleEn, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding DetailItem.ExampleZh, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="熟悉程度" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Button Content="陌生" Style="{StaticResource OutlineButton}" Click="MarkNew_Click"
                                    Width="70" Padding="10,8" Margin="0,0,8,0"/>
                            <Button Content="学习中" Style="{StaticResource OutlineButton}" Click="MarkLearning_Click"
                                    Width="70" Padding="10,8" Margin="0,0,8,0"/>
                            <Button Content="已掌握" Style="{StaticResource OutlineButton}" Click="MarkMastered_Click"
                                    Width="70" Padding="10,8"/>
                        </StackPanel>

                        <Grid>
                            <Button Content="删除" HorizontalAlignment="Left" Style="{StaticResource DangerButton}"
                                    Command="{Binding DeleteCommand}" CommandParameter="{Binding DetailItem}"/>
                            <Button Content="保存修改" HorizontalAlignment="Right" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SaveEditCommand}" CommandParameter="{Binding DetailItem}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource SectionPanel}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDetailVisible}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="选择一个词条" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="可查看释义、例句并调整熟悉程度" FontSize="13"
                               Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,7,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
